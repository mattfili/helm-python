    },
    "/search/repositories": {
      "get": {
        "operationId": "searchRepos",
        "summary": "Search repositories",
        "tags": ["search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["stars", "forks", "help-wanted-issues", "updated"] }
          },
          {
            "name": "order",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Search results" }
        }
      }
    },
    "/search/issues": {
      "get": {
        "operationId": "searchIssues",
        "summary": "Search issues and pull requests",
        "tags": ["search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["comments", "reactions", "created", "updated"] }
          },
          {
            "name": "order",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Search results" }
        }
      }
    },
    "/search/users": {
      "get": {
        "operationId": "searchUsers",
