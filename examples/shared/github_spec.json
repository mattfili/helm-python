          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "per_page",
