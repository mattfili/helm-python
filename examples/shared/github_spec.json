        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Repository topics" }
        }
      }
    },
    "/repos/{owner}/{repo}/readme": {
      "get": {
        "operationId": "getRepoReadme",
        "summary": "Get a repository README",
        "tags": ["repos"],
        "parameters": [
          {
            "name": "owner",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "README content" }
        }
      }
    },
    "/repos/{owner}/{repo}/releases": {
      "get": {
        "operationId": "listRepoReleases",
