          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["followers", "repositories", "joined"] }
          },
          {
            "name": "order",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
